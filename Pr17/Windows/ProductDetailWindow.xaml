<Window x:Class="Pr17.Windows.ProductDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Информация о товаре" Height="400" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Изображение -->
        <Image x:Name="ProductImage" Grid.Row="0" Height="150" Stretch="Uniform" Margin="0,0,0,10"/>

        <!-- Информация -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="NameText" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" Margin="0,5"/>
                <TextBlock x:Name="PriceText" FontSize="16" Margin="0,5"/>
                <TextBlock x:Name="DiscountText" FontSize="14" Foreground="Red" Margin="0,5"/>
                <TextBlock x:Name="RatingText" FontSize="14" Margin="0,5"/>
                <TextBlock x:Name="ManufacturerText" FontSize="14" Margin="0,5"/>
                <TextBlock x:Name="TypeText" FontSize="14" Margin="0,5"/>
                <TextBlock x:Name="DescriptionText" FontSize="14" TextWrapping="Wrap" Margin="0,10"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="AddToCartButton" Content="Добавить в корзину" Width="140" Margin="5" Click="AddToCartButton_Click"/>
            <Button Content="Закрыть" Width="80" Margin="5" Click="CloseButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>