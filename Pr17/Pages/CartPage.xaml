<Page x:Class="Pr17.Pages.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Корзина">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Button x:Name="BackButton" Content="← Назад" Click="BackButton_Click" Margin="10" HorizontalAlignment="Left"/>

        <ScrollViewer Grid.Row="1">
            <ItemsControl x:Name="CartItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="200" Margin="10" Padding="10" BorderBrush="Gray" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding ProductName}" FontWeight="Bold" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Price, StringFormat='Цена: {0:C}'}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="-" Click="DecreaseQuantity_Click" Tag="{Binding}" Width="25"/>
                                    <TextBlock Text="{Binding Quantity}" Width="30" TextAlignment="Center" VerticalAlignment="Center"/>
                                    <Button Content="+" Click="IncreaseQuantity_Click" Tag="{Binding}" Width="25"/>
                                </StackPanel>
                                <Button Content="Удалить" Click="RemoveFromCart_Click" Tag="{Binding}" Margin="0,5"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button x:Name="OrderButton" Grid.Row="2" Content="Оформить заказ" Width="150" Margin="10" HorizontalAlignment="Right" Click="OrderButton_Click"/>
    </Grid>
</Page>