<Page x:Class="Pr17.Pages.AppointmentConfirmationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Подтверждение записи">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Button x:Name="BackButton" Content="← Назад" Click="BackButton_Click" Margin="0,0,0,10" HorizontalAlignment="Left"/>

        <TextBlock x:Name="ServiceText" Grid.Row="1" FontWeight="Bold"/>
        <TextBlock x:Name="MasterText" Grid.Row="2"/>
        <TextBlock x:Name="DateTimeText" Grid.Row="3" Margin="0,5"/>

        <TextBlock Grid.Row="4" Text="Способ оплаты:" Margin="0,10,0,5"/>
        <ComboBox x:Name="PaymentCombo" Grid.Row="5" Width="200" HorizontalAlignment="Left"/>

        <TextBlock Grid.Row="6" Text="Комментарий:" Margin="0,10,0,5"/>
        <TextBox x:Name="CommentBox" Grid.Row="6" Height="60" TextWrapping="Wrap" VerticalAlignment="Top" Margin="0,25,0,0"/>

        <Button x:Name="ConfirmButton" Grid.Row="7" Content="Записаться" Width="120" HorizontalAlignment="Left" Click="ConfirmButton_Click" Margin="0,20"/>
    </Grid>
</Page>