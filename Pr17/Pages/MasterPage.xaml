<Page x:Class="Pr17.Pages.MasterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Кабинет мастера">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <Button x:Name="BackButton" Content="← Назад" Click="BackButton_Click" Margin="10" HorizontalAlignment="Left"/>
            <Button x:Name="EditServicesButton" Content="Изменить список услуг" Click="EditServicesButton_Click" Margin="10" HorizontalAlignment="Left"/>
        </StackPanel>

        <DataGrid x:Name="AppointmentsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Margin="10"
                  MouseDoubleClick="AppointmentsGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat='dd.MM.yyyy'}"/>
                <DataGridTextColumn Header="Время" Binding="{Binding Time}"/>
                <DataGridTextColumn Header="Услуга" Binding="{Binding ServiceTypeName}"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>