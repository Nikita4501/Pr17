<Page x:Class="Pr17.Pages.StartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Космическая ложа">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="10">
            <WrapPanel>
                <Button x:Name="LoginButton" Content="Вход" Click="LoginButton_Click" Margin="5" Width="80"/>
                <Button x:Name="RegisterButton" Content="Регистрация" Click="RegisterButton_Click" Margin="5" Width="90"/>
                <Button x:Name="AccountButton" Content="Аккаунт" Click="AccountButton_Click" Margin="5" Width="80" Visibility="Collapsed"/>
                <Button x:Name="LogoutButton" Content="Выход" Click="LogoutButton_Click" Margin="5" Width="80" Visibility="Collapsed"/>
                <Button x:Name="ProductsButton" Content="Товары" Click="ProductsButton_Click" Margin="5" Width="80"/>
            </WrapPanel>
            <WrapPanel Margin="0,10,0,0">
                <TextBlock Text="Тип услуги:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox x:Name="ServiceTypeFilter" Width="200" Margin="5" SelectionChanged="ApplyFilters"/>
                <TextBlock Text="Мастер:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox x:Name="MasterFilter" Width="200" Margin="5" SelectionChanged="ApplyFilters"/>
            </WrapPanel>
        </StackPanel>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Услуги" Grid.Column="0" Margin="5">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ListBox x:Name="ServiceTypesListBox" SelectionChanged="ServiceTypesListBox_SelectionChanged" Margin="5">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Margin="0,0,0,5" Padding="8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="Gray" FontSize="12" Margin="0,2,0,0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <TextBlock Text="Цена: " FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Price, StringFormat='{}{0:C}'}" Foreground="Green"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Длительность: " FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Duration, StringFormat='{}{0} мин'}" Foreground="DodgerBlue"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </GroupBox>

            <GroupBox Header="Мастера" Grid.Column="1" Margin="5">
                <ListBox x:Name="MastersListBox" SelectionChanged="MastersListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding FullName}" FontWeight="Bold"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>
        </Grid>
    </Grid>
</Page>