<Page x:Class="Pr17.Pages.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Товары">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="10">
            <Button x:Name="BackButton" Content="← Назад" Click="BackButton_Click" HorizontalAlignment="Left"/>
            <WrapPanel Margin="0,10,0,0">
                <TextBox x:Name="SearchBox" Width="200" Margin="5" TextChanged="ApplyFilters"/>
                <ComboBox x:Name="TypeFilter" Width="150" Margin="5" SelectionChanged="ApplyFilters" DisplayMemberPath="Name"/>
                <ComboBox x:Name="ManufacturerFilter" Width="150" Margin="5" SelectionChanged="ApplyFilters" DisplayMemberPath="Name"/>
                <ComboBox x:Name="SortCombo" Width="120" Margin="5" SelectionChanged="ApplyFilters">
                    <ComboBoxItem Content="По рейтингу ↑" Tag="RatingAsc"/>
                    <ComboBoxItem Content="По рейтингу ↓" Tag="RatingDesc"/>
                </ComboBox>
                <Button x:Name="CartButton" Content="Корзина" Click="CartButton_Click" Margin="5"/>
            </WrapPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <ItemsControl x:Name="ProductsItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="ProductBorder" Width="200" Margin="10" Padding="10" BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Discount}" Value="15">
                                            <Setter Property="Background" Value="LightGreen"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <Image Source="{Binding ImagePath}" Height="100" Stretch="Uniform"/>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Price, StringFormat='Цена: {0:C}'}"/>
                                <TextBlock Text="{Binding Discount, StringFormat='Скидка: {0}%'}" Foreground="Red"/>
                                <TextBlock Text="{Binding Rating, StringFormat='Рейтинг: {0}'}"/>
                                <Button Content="Подробнее" Click="ProductDetail_Click" Tag="{Binding}" Margin="0,5"/>
                                <Button Content="В корзину" Click="AddToCart_Click" Tag="{Binding}"
                                        IsEnabled="{Binding IsLoggedIn}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>